包 工具包;

// 简单工具包
函数 入口() {
    打印行("=== 工具包演示 ===");
    变量 最大 = 找最大值(3, 7);
    变量 最小 = 找最小值(3, 7);
    打印行("最大值(3,7) =", 最大);
    打印行("最小值(3,7) =", 最小);
}

公开 函数 找最大值(a: 整数, b: 整数) : 整数 {
    如果 a > b {
        返回 a;
    } 否则 {
        返回 b;
    }
}

公开 函数 找最小值(a: 整数, b: 整数) : 整数 {
    如果 a < b {
        返回 a;
    } 否则 {
        返回 b;
    }
}