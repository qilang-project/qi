// 异步LLM对话示例
// 演示如何使用异步API调用大模型

包 主程序;

导入 标准库.大模型;
导入 标准库.操作系统;

函数 入口() {
    打印行("========================================");
    打印行("     异步 LLM 对话示例");
    打印行("========================================");
    打印行("");

    // 尝试从 .env 文件加载配置
    打印行("📖 加载 API 配置...");
    变量 env文件: 字符串 = "示例/大模型/.env";
    变量 加载数量: 整数 = 操作系统.加载环境文件(env文件);

    如果 (加载数量 > 0) {
        打印("✅ 从 .env 文件加载了 ");
        打印行(加载数量);
        打印行(" 个环境变量");
    }

    // 读取环境变量（使用默认值）
    变量 端点: 字符串 = "https://api.deepseek.com/v1/chat/completions";
    变量 模型: 字符串 = "deepseek-chat";
    变量 密钥: 字符串 = 操作系统.获取环境变量("LLM_API_KEY");

    打印("");
    打印("✓ API端点: ");
    打印行(端点);
    打印("✓ 模型: ");
    打印行(模型);
    打印("✓ API密钥: ");
    打印行(密钥);
    打印行("");

    // 创建LLM会话
    变量 会话: 整数 = 大模型.创建会话(端点, 模型, 密钥);

    如果 (会话 < 0) {
        打印行("❌ 创建会话失败");
        返回;
    }

    打印行("✅ LLM会话创建成功！");
    打印行("");
    打印行("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    打印行("【异步并发请求演示】");
    打印行("");

    // 异步调用 - 不会阻塞，立即返回Future
    打印行("📤 发送第一个问题（异步）...");
    变量 未来1: 未来<字符串> = 大模型.异步对话(会话, "你好！请用一句话介绍你自己。");

    打印行("📤 发送第二个问题（异步）...");
    变量 未来2: 未来<字符串> = 大模型.异步对话(会话, "1+1等于几？请简单回答。");

    打印行("📤 发送第三个问题（异步）...");
    变量 未来3: 未来<字符串> = 大模型.异步对话(会话, "请用一句话解释什么是异步编程。");

    打印行("");
    打印行("✓ 三个请求已并发发送，现在等待结果...");
    打印行("");

    // 现在等待结果 - 使用 等待 关键字
    打印行("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    打印行("【获取异步结果】");
    打印行("");

    打印行("⏳ 等待第一个回答...");
    变量 响应1: 字符串 = 等待 未来1;
    打印("🤖 AI回答1: ");
    打印行(响应1);
    打印行("");

    打印行("⏳ 等待第二个回答...");
    变量 响应2: 字符串 = 等待 未来2;
    打印("🤖 AI回答2: ");
    打印行(响应2);
    打印行("");

    打印行("⏳ 等待第三个回答...");
    变量 响应3: 字符串 = 等待 未来3;
    打印("🤖 AI回答3: ");
    打印行(响应3);
    打印行("");

    // 关闭会话
    打印行("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    大模型.关闭会话(会话);
    打印行("✅ 会话已关闭");
    打印行("");
    打印行("========================================");
    打印行("       测试完成");
    打印行("========================================");

    返回;
}
