// 选择排序算法 - Selection Sort
// 时间复杂度: O(n²)

函数 查找最小值索引(起始: 整数, 结束: 整数) : 整数 {
    变量 最小索引: 整数 = 起始;
    变量 i: 整数 = 起始 + 1;

    当 i < 结束 {
        // 比较并更新最小值索引
        i = i + 1;
    }

    返回 最小索引;
}

函数 挑选排序(大小: 整数) {
    变量 i: 整数 = 0;
    变量 最小位置: 整数 = 0;

    当 i < 大小 - 1 {
        最小位置 = 查找最小值索引(i, 大小);
        // 交换当前位置和最小值位置的元素
        打印行("挑选第");
        打印行(i);
        打印行("小的元素");
        i = i + 1;
    }

    打印行("挑选排序完成");
}

函数 入口() {
    打印行("=== 挑选排序算法演示 ===");
    挑选排序(5);
}
