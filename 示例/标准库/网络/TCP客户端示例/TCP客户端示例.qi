// TCP 客户端示例
// 演示如何连接到 TCP 服务器，发送和接收数据

包 主程序;

导入 标准库.网络;
导入 标准库.输入输出;

函数 入口() {
    输入输出::打印行("=== TCP 客户端示例 ===");

    // 连接到本地 TCP 服务器
    变量 主机: 字符串 = "127.0.0.1";
    变量 端口: 整数 = 8888;

    输入输出::打印行("正在连接到服务器: " + 主机 + ":" + 端口转字符串(端口));

    变量 连接句柄: 整数 = 网络::TCP连接(主机, 端口);

    如果 (连接句柄 < 0) {
        输入输出::打印行("连接失败！错误代码: " + 整数转字符串(连接句柄));
        返回;
    }

    输入输出::打印行("连接成功！句柄: " + 整数转字符串(连接句柄));

    // 发送消息到服务器
    变量 消息: 字符串 = "你好，服务器！这是来自 Qi 客户端的消息。";
    变量 发送结果: 整数 = 网络::TCP写入(连接句柄, 消息);

    如果 (发送结果 < 0) {
        输入输出::打印行("发送失败！错误代码: " + 整数转字符串(发送结果));
        网络::TCP关闭(连接句柄);
        返回;
    }

    输入输出::打印行("已发送: " + 整数转字符串(发送结果) + " 字节");

    // 接收服务器响应
    变量 缓冲区大小: 整数 = 1024;
    变量 响应: 字符串 = 网络::TCP读取(连接句柄, 缓冲区大小);

    如果 (响应 == "") {
        输入输出::打印行("接收失败或连接已关闭");
    } 否则 {
        输入输出::打印行("收到响应: " + 响应);
    }

    // 获取统计信息
    变量 已读字节: 整数 = 网络::TCP已读字节(连接句柄);
    变量 已写字节: 整数 = 网络::TCP已写字节(连接句柄);

    输入输出::打印行("统计信息:");
    输入输出::打印行("  已读取: " + 整数转字符串(已读字节) + " 字节");
    输入输出::打印行("  已发送: " + 整数转字符串(已写字节) + " 字节");

    // 关闭连接
    变量 关闭结果: 整数 = 网络::TCP关闭(连接句柄);

    如果 (关闭结果 == 0) {
        输入输出::打印行("连接已关闭");
    } 否则 {
        输入输出::打印行("关闭失败！错误代码: " + 整数转字符串(关闭结果));
    }
}

// 辅助函数：整数转字符串
函数 整数转字符串(值: 整数) : 字符串 {
    // 简化版本，实际应使用标准库
    如果 (值 == 0) {
        返回 "0";
    }

    变量 结果: 字符串 = "";
    变量 数字: 整数 = 值;
    变量 是负数: 布尔 = 假;

    如果 (数字 < 0) {
        是负数 = 真;
        数字 = 0 - 数字;
    }

    当 (数字 > 0) {
        变量 余数: 整数 = 数字 % 10;
        数字 = 数字 / 10;

        如果 (余数 == 0) { 结果 = "0" + 结果; }
        如果 (余数 == 1) { 结果 = "1" + 结果; }
        如果 (余数 == 2) { 结果 = "2" + 结果; }
        如果 (余数 == 3) { 结果 = "3" + 结果; }
        如果 (余数 == 4) { 结果 = "4" + 结果; }
        如果 (余数 == 5) { 结果 = "5" + 结果; }
        如果 (余数 == 6) { 结果 = "6" + 结果; }
        如果 (余数 == 7) { 结果 = "7" + 结果; }
        如果 (余数 == 8) { 结果 = "8" + 结果; }
        如果 (余数 == 9) { 结果 = "9" + 结果; }
    }

    如果 (是负数) {
        结果 = "-" + 结果;
    }

    返回 结果;
}

函数 端口转字符串(端口: 整数) : 字符串 {
    返回 整数转字符串(端口);
}
