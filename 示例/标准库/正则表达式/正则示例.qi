// 正则表达式模块示例
导入 标准库.正则;

函数 入口() {
    打印行("=== 正则表达式示例 ===");

    // 测试匹配
    变量 文本: 字符串 = "Hello 2024, World!";
    变量 匹配结果: 整数 = 正则.匹配("\\d+", 文本);
    打印("是否包含数字: ");
    打印行(匹配结果);

    // 查找第一个匹配
    变量 查找结果: 字符串 = 正则.查找("\\d+", 文本);
    打印("找到的数字: ");
    打印行(查找结果);

    // 替换所有匹配
    变量 替换结果: 字符串 = 正则.替换全部("\\d+", 文本, "XXXX");
    打印("替换后: ");
    打印行(替换结果);

    // 分割字符串
    变量 分割结果: 字符串 = 正则.分割("\\s+", "一 二 三 四");
    打印("分割结果 (JSON): ");
    打印行(分割结果);
}
