// 操作系统模块 - 加载 .env 文件示例
// 演示如何从 .env 文件批量加载环境变量

包 主程序;

导入 标准库.操作系统;

函数 入口() {
    打印行("========================================");
    打印行("     加载 .env 文件示例");
    打印行("========================================");
    打印行("");

    // 首先创建一个测试 .env 文件
    打印行("📝 测试环境变量加载功能");
    打印行("");

    // 设置 .env 文件路径
    变量 env文件路径: 字符串 = "示例/高级/大模型/.env.example";

    打印("📂 .env 文件路径: ");
    打印行(env文件路径);
    打印行("");

    // 加载环境变量文件
    打印行("⏳ 正在加载环境变量文件...");
    变量 加载数量: 整数 = 操作系统.加载环境文件(env文件路径);

    打印行("");

    如果 (加载数量 > 0) {
        打印("✅ 成功加载 ");
        打印行(加载数量);
        打印行(" 个环境变量");
        打印行("");

        // 验证已加载的环境变量
        打印行("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        打印行("【验证加载的环境变量】");
        打印行("");

        变量 api_key: 字符串 = 操作系统.获取环境变量("LLM_API_KEY");
        打印("🔑 LLM_API_KEY = ");
        打印行(api_key);

        打印行("");
        打印行("💡 提示: 如果看到 'your_api_key_here'，");
        打印行("   说明环境变量成功从 .env.example 文件加载");
    } 否则 {
        打印行("❌ 加载环境变量文件失败");
        打印行("");
        打印行("可能的原因:");
        打印行("  1. 文件不存在");
        打印行("  2. 文件路径不正确");
        打印行("  3. 没有读取权限");
    }

    打印行("");
    打印行("========================================");
    打印行("       测试完成");
    打印行("========================================");

    返回;
}
