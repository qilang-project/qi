# LLM API 配置示例
# 复制此文件为 .env 并填入真实的API密钥

# Base URL / API端点 (二选一；可填 base URL 或完整 chat completions 端点)
LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_ENDPOINT=https://api.deepseek.com/v1/chat/completions

# 模型名称 (可选，默认使用 deepseek-chat)
LLM_MODEL=deepseek-chat

# API密钥 (必需)
LLM_API_KEY=your_api_key_here

# 使用方法:
# 1. 复制此文件: cp .env.example .env
# 2. 编辑 .env 文件，填入真实的API密钥
# 3. 在运行程序前导入环境变量:
#    source .env
#    或
#    export $(cat .env | xargs)
# 4. 运行程序:
#    cargo run --release --bin qi -- run 示例/大模型/异步对话示例.qi
#    cargo run --release --bin qi -- run 示例/大模型/流式对话示例/流式对话示例.qi
#    cargo run --release --bin qi -- run 示例/大模型/工具调用示例/工具调用示例.qi
