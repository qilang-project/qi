// 流式大模型对话示例
// 演示如何逐片段读取模型输出

包 主程序;

导入 标准库.大模型;
导入 标准库.操作系统;

函数 入口() {
    打印行("========================================");
    打印行("       流式大模型对话示例");
    打印行("========================================");

    操作系统.加载环境文件("示例/高级/大模型/.env");

    变量 端点: 字符串 = 操作系统.获取环境变量("LLM_BASE_URL");
    如果 (端点 == "") {
        端点 = 操作系统.获取环境变量("LLM_API_ENDPOINT");
    }
    如果 (端点 == "") {
        端点 = "https://api.deepseek.com/v1";
    }

    变量 模型: 字符串 = 操作系统.获取环境变量("LLM_MODEL");
    如果 (模型 == "") {
        模型 = "deepseek-chat";
    }

    变量 密钥: 字符串 = 操作系统.获取环境变量("LLM_API_KEY");
    变量 会话: 整数 = 大模型.创建会话(端点, 模型, 密钥);

    如果 (会话 < 0) {
        打印行("创建会话失败");
        返回;
    }

    大模型.设置配置(会话, "temperature", "0.7");
    大模型.设置配置(会话, "max_tokens", "800");

    打印行("开始流式输出:");
    变量 流: 整数 = 大模型.流式对话(会话, "请用三句话介绍 Qi 语言。");

    如果 (流 < 0) {
        打印行("打开流失败");
        大模型.关闭会话(会话);
        返回;
    }

    变量 继续读取: 整数 = 1;
    当 (继续读取 == 1) {
        变量 片段: 字符串 = 大模型.读取流(流);
        如果 (片段 == "") {
            继续读取 = 0;
        } 否则 {
            打印(片段);
        }
    }

    打印行("");
    大模型.关闭流(流);
    大模型.关闭会话(会话);
}
