// 大模型工具调用示例
// 工具定义使用 JSON Schema，模型响应返回 assistant message JSON。

包 主程序;

导入 标准库.大模型;
导入 标准库.操作系统;
导入 标准库.JSON;

函数 查询天气(参数: 字符串) : 字符串 {
    返回 JSON.从键值("城市=上海;天气=晴;温度=25°C;风力=微风");
}

函数 入口() {
    打印行("========================================");
    打印行("       大模型工具调用示例");
    打印行("========================================");

    操作系统.加载环境文件("示例/高级/大模型/.env");

    变量 端点: 字符串 = 操作系统.获取环境变量("LLM_BASE_URL");
    如果 (端点 == "") {
        端点 = 操作系统.获取环境变量("LLM_API_ENDPOINT");
    }
    如果 (端点 == "") {
        端点 = "https://api.deepseek.com/v1";
    }

    变量 模型: 字符串 = 操作系统.获取环境变量("LLM_MODEL");
    如果 (模型 == "") {
        模型 = "deepseek-chat";
    }

    变量 密钥: 字符串 = 操作系统.获取环境变量("LLM_API_KEY");
    变量 会话: 整数 = 大模型.创建会话(端点, 模型, 密钥);

    如果 (会话 < 0) {
        打印行("创建会话失败");
        返回;
    }

    变量 参数结构: 字符串 = "{\"type\":\"object\",\"properties\":{\"城市\":{\"type\":\"string\",\"description\":\"城市名称\"}},\"required\":[\"城市\"]}";
    变量 注册结果: 整数 = 大模型.注册工具(
        会话,
        "查询天气",
        "查询指定城市的当前天气",
        参数结构
    );

    如果 (注册结果 < 0) {
        打印行("注册工具失败");
        大模型.关闭会话(会话);
        返回;
    }

    变量 回复: 字符串 = 大模型.工具对话(会话, "上海现在天气怎么样？需要时请调用工具。");
    打印行("模型返回的 assistant message JSON:");
    打印行(回复);

    如果 (大模型.有工具调用(回复) == 1) {
        变量 调用ID: 字符串 = 大模型.工具调用ID(回复);
        变量 工具名: 字符串 = 大模型.工具调用名称(会话, 回复);
        变量 参数: 字符串 = 大模型.工具调用参数(回复);

        打印("工具名称: ");
        打印行(工具名);
        打印("工具参数: ");
        打印行(参数);

        如果 (工具名 == "查询天气") {
            变量 工具结果: 字符串 = 查询天气(参数);
            大模型.添加工具结果(会话, 调用ID, 工具名, 工具结果);

            变量 最终回复: 字符串 = 大模型.继续工具对话(会话);
            打印行("最终回复:");
            打印行(最终回复);
        }
    } 否则 {
        打印行("模型没有请求工具调用。");
    }

    大模型.清空工具(会话);
    大模型.关闭会话(会话);
}
