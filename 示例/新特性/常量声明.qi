// 常量声明示例 - Constant Declaration Example
// 常量一旦绑定就不能修改

函数 入口() {
    // 声明常量（必须初始化）
    常量 圆周率: 浮点数 = 3.14159;
    常量 最大值: 整数 = 100;
    常量 应用名称: 字符串 = "气语言";
    常量 是调试: 布尔 = 真;

    // 使用常量
    打印行("圆周率:");
    打印行(圆周率);
    打印行("最大值:");
    打印行(最大值);
    打印行("应用名称:");
    打印行(应用名称);

    // 变量可以修改
    变量 计数: 整数 = 0;
    计数 = 计数 + 1;
    打印行("计数:");
    打印行(计数);

    // 常量用于计算
    变量 面积: 浮点数 = 圆周率 * 10.0 * 10.0;
    打印行("半径10的圆面积:");
    打印行(面积);

    打印行("常量示例完成");
}
