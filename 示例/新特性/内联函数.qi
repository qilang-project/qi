// 内联函数示例 - Inline Function Example
// 演示内联函数语法

// 内联函数 - 编译器会尝试在调用点展开此函数
内联 函数 平方(x: 整数) : 整数 {
    返回 x * x;
}

内联 函数 立方(x: 整数) : 整数 {
    返回 x * x * x;
}

// 带有多个参数的内联函数
内联 函数 最大值(a: 整数, b: 整数) : 整数 {
    如果 a > b {
        返回 a;
    }
    返回 b;
}

函数 入口() {
    变量 x: 整数 = 5;

    变量 结果1: 整数 = 平方(x);
    打印行(结果1);

    变量 结果2: 整数 = 立方(x);
    打印行(结果2);

    变量 结果3: 整数 = 最大值(10, 20);
    打印行(结果3);
}
