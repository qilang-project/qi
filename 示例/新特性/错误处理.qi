// 错误处理示例 - Error Handling Example
// 演示尝试/捕获/最终语法

函数 入口() {
    // 基本的尝试/捕获
    尝试 {
        打印行("尝试执行可能出错的操作");
    } 捕获 {
        打印行("发生错误");
    }

    // 带有最终块的尝试/捕获
    尝试 {
        打印行("另一个尝试块");
    } 捕获 错误 {
        打印行("捕获到错误");
    } 最终 {
        打印行("最终块总是执行");
    }

    // 只有最终块
    尝试 {
        打印行("尝试块");
    } 最终 {
        打印行("清理资源");
    }

    打印行("程序正常结束");
}
