// 结果类型和选项类型示例 - Result and Option Types Example
// 演示结果<T,E>和选项<T>类型语法

// 使用结果类型的函数
函数 安全除法(被除数: 整数, 除数: 整数) : 结果<整数, 字符串> {
    如果 除数 == 0 {
        // 返回错误
        返回 错误("除数不能为零");
    }
    // 返回成功结果
    返回 成功(被除数 / 除数);
}

// 使用选项类型的函数
函数 查找值(输入值: 整数) : 选项<整数> {
    如果 输入值 > 0 {
        返回 有值(输入值);
    }
    // 返回空值
    返回 空值;
}

函数 入口() {
    // 结果类型使用示例
    变量 除法返回1 = 安全除法(10, 2);
    变量 除法返回2 = 安全除法(10, 0);

    // 选项类型使用示例
    变量 找到的值 = 查找值(42);

    打印行("结果类型示例完成");
}
