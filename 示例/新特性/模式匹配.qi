// 模式匹配示例 - Pattern Matching Example
// 演示匹配表达式语法

函数 入口() {
    变量 数字: 整数 = 2;

    // 基本模式匹配
    变量 匹配后 = 匹配 数字 {
        1 => { 打印行("数字是一"); }
        2 => { 打印行("数字是二"); }
        3 => { 打印行("数字是三"); }
        _ => { 打印行("数字是其他值"); }
    };

    // 带变量绑定的匹配
    变量 值: 整数 = 42;
    变量 绑定后 = 匹配 值 {
        0 => { 打印行("值是零"); }
        x => { 打印行("值被绑定到变量x"); }
    };

    打印行("模式匹配完成");
}
