// 测试新的结构体实例化语法
包 主程序;

类型 点 {
    整数 横坐标;
    整数 纵坐标;
}

函数 入口() {
    // 新语法：新建 结构体名 { 字段: 值 }
    变量 点1 = 新建 点 { 横坐标: 10, 纵坐标: 20 };
    打印行("点1.横坐标 =", 点1.横坐标);
    打印行("点1.纵坐标 =", 点1.纵坐标);

    // 旧语法仍然有效
    变量 点2 = (点 { 横坐标: 30, 纵坐标: 40 });
    打印行("点2.横坐标 =", 点2.横坐标);
    打印行("点2.纵坐标 =", 点2.纵坐标);
}
