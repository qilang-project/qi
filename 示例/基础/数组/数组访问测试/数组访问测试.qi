包 主程序;

函数 入口() {
    打印行("=== 数组访问测试 ===");
    打印行("");

    // 创建浮点数数组
    变量 数据: 数组<浮点数> = [1.5, 2.5, 3.5, 4.5];
    打印行("创建了浮点数数组: [1.5, 2.5, 3.5, 4.5]");
    打印行("");

    // 访问数组元素
    变量 第一个: 浮点数 = 数据[0];
    变量 第二个: 浮点数 = 数据[1];
    变量 第三个: 浮点数 = 数据[2];

    打印("第一个元素: ");
    打印行(第一个);

    打印("第二个元素: ");
    打印行(第二个);

    打印("第三个元素: ");
    打印行(第三个);

    打印行("");
    打印行("=== 测试完成 ===");
}
