// 数学计算测试
// 测试标准库数学函数与内存管理的配合

包 主程序;

函数 入口() {
    打印("=== 数学计算测试 ===");

    // 基本算术
    变量 加法 = 10 + 20;
    变量 减法 = 50 - 15;
    变量 乘法 = 6 * 7;
    变量 除法 = 100 / 5;

    打印("加法 10+20=");
    打印(加法);

    打印("减法 50-15=");
    打印(减法);

    打印("乘法 6*7=");
    打印(乘法);

    打印("除法 100/5=");
    打印(除法);

    // 组合运算
    变量 组合 = (10 + 5) * 2;
    打印("组合运算 (10+5)*2=");
    打印(组合);

    打印("数学计算测试完成");
}
