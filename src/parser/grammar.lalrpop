use crate::parser::ast::*;
use crate::parser::unescape_string;

grammar;

pub Program: Program = {
    <package:PackageDeclaration?> <imports:ImportStatement*> <statements:Statement*> => Program {
        package_name: package,
        imports,
        statements,
        source_span: Default::default(),
    }
};

PackageDeclaration: String = {
    "包" <name:Identifier> ";" => name,
    "包" <name:Identifier> "；" => name
};

ImportStatement: ImportStatement = {
    "导入" <path:ModulePath> ";" => ImportStatement {
        module_path: path,
        items: None,
        alias: None,
        is_public: false,
        span: Default::default(),
    },
    "导入" <path:ModulePath> "；" => ImportStatement {
        module_path: path,
        items: None,
        alias: None,
        is_public: false,
        span: Default::default(),
    },
    "导入" <path:ModulePath> "作为" <alias:Identifier> ";" => ImportStatement {
        module_path: path,
        items: None,
        alias: Some(alias),
        is_public: false,
        span: Default::default(),
    },
    "导入" <path:ModulePath> "作为" <alias:Identifier> "；" => ImportStatement {
        module_path: path,
        items: None,
        alias: Some(alias),
        is_public: false,
        span: Default::default(),
    },
    "公开" "导入" <path:ModulePath> ";" => ImportStatement {
        module_path: path,
        items: None,
        alias: None,
        is_public: true,
        span: Default::default(),
    },
    "公开" "导入" <path:ModulePath> "；" => ImportStatement {
        module_path: path,
        items: None,
        alias: None,
        is_public: true,
        span: Default::default(),
    },
};

ModulePath: Vec<String> = {
    // Relative paths: ./module, ../module, ../../module.submodule
    // Can use either . or / as separator after initial . or ..
    <first:RelativePathStart> <rest:(PathSep <PathComponent>)*> => {
        let mut path = vec![first];
        path.extend(rest);
        path
    },
    // Traditional dot-separated paths: 标准库.io
    <first:Identifier> <rest:("." <Identifier>)*> => {
        let mut path = vec![first];
        path.extend(rest);
        path
    }
};

RelativePathStart: String = {
    "." => ".".to_string(),
    ".." => "..".to_string(),
};

PathSep: () = {
    "." => (),
    "/" => (),
};

PathComponent: String = {
    "." => ".".to_string(),
    ".." => "..".to_string(),
    <id:Identifier> => id,
};

Statement: AstNode = {
    VariableDeclaration,
    FunctionDeclaration,
    InlineFunctionDeclaration,
    TypeDeclaration,
    UnionDeclaration,
    TraitDeclaration,
    ImplementationBlock,
    ReturnStatement,
    BreakStatement,
    ContinueStatement,
    IfStatement,
    WhileStatement,
    ForStatement,
    TryStatement,
    ThrowStatement,
    <e:Expr> ";" => AstNode::表达式语句(ExpressionStatement {
        expression: Box::new(e),
        span: Default::default(),
    }),
    <e:Expr> "；" => AstNode::表达式语句(ExpressionStatement {
        expression: Box::new(e),
        span: Default::default(),
    }),
    // Select statement must be separate to avoid conflicts with expressions
    "选择" "{" <cases:SelectCaseList> <default_case:DefaultCase?> "}" => AstNode::选择表达式(SelectExpression {
        cases,
        default_case,
        span: Default::default(),
    }),
};

VariableDeclaration: AstNode = {
    "变量" <name:Identifier> ":" <type_annotation:Type> "=" <value:Expr> ";" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: true,
        span: Default::default(),
    }),
    "变量" <name:Identifier> "：" <type_annotation:Type> "=" <value:Expr> ";" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: true,
        span: Default::default(),
    }),
    "变量" <name:Identifier> ":" <type_annotation:Type> "=" <value:Expr> "；" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: true,
        span: Default::default(),
    }),
    "变量" <name:Identifier> "：" <type_annotation:Type> "=" <value:Expr> "；" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: true,
        span: Default::default(),
    }),
    "变量" <name:Identifier> "=" <value:Expr> ";" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: None,
        initializer: Some(Box::new(value)),
        is_mutable: true,
        span: Default::default(),
    }),
    "变量" <name:Identifier> "=" <value:Expr> "；" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: None,
        initializer: Some(Box::new(value)),
        is_mutable: true,
        span: Default::default(),
    }),
    "常量" <name:Identifier> ":" <type_annotation:Type> "=" <value:Expr> ";" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: false,
        span: Default::default(),
    }),
    "常量" <name:Identifier> "：" <type_annotation:Type> "=" <value:Expr> ";" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: false,
        span: Default::default(),
    }),
    "常量" <name:Identifier> ":" <type_annotation:Type> "=" <value:Expr> "；" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: false,
        span: Default::default(),
    }),
    "常量" <name:Identifier> "：" <type_annotation:Type> "=" <value:Expr> "；" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: Some(type_annotation),
        initializer: Some(Box::new(value)),
        is_mutable: false,
        span: Default::default(),
    }),
    "常量" <name:Identifier> "=" <value:Expr> ";" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: None,
        initializer: Some(Box::new(value)),
        is_mutable: false,
        span: Default::default(),
    }),
    "常量" <name:Identifier> "=" <value:Expr> "；" => AstNode::变量声明(VariableDeclaration {
        name,
        type_annotation: None,
        initializer: Some(Box::new(value)),
        is_mutable: false,
        span: Default::default(),
    }),
