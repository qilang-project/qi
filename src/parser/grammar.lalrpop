        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    // 混合标点符号版本：英文括号 + 中文大括号
    <vis:Visibility> "函数" <name:Identifier> "(" ")" ":" <return_type:Type> "【" <body:Statement*> "】" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: vec![],
        return_type: Some(return_type),
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    <vis:Visibility> "函数" <name:Identifier> "(" ")" "【" <body:Statement*> "】" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: vec![],
        return_type: None,
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    <vis:Visibility> "函数" <name:Identifier> "(" <params:ParameterList> ")" ":" <return_type:Type> "【" <body:Statement*> "】" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: params,
        return_type: Some(return_type),
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    <vis:Visibility> "函数" <name:Identifier> "(" <params:ParameterList> ")" "【" <body:Statement*> "】" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: params,
        return_type: None,
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    // 混合标点符号版本：中文括号 + 英文大括号
    <vis:Visibility> "函数" <name:Identifier> "（" "）" ":" <return_type:Type> "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: vec![],
        return_type: Some(return_type),
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    <vis:Visibility> "函数" <name:Identifier> "（" "）" "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: vec![],
        return_type: None,
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    <vis:Visibility> "函数" <name:Identifier> "（" <params:ParameterList> "）" ":" <return_type:Type> "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: params,
        return_type: Some(return_type),
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
    <vis:Visibility> "函数" <name:Identifier> "（" <params:ParameterList> "）" "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: params,
        return_type: None,
        body,
        visibility: vis,
        is_inline: false,
        span: Default::default(),
    }),
};

ReturnStatement: AstNode = {
    "返回" <value:Expr> ";" => AstNode::返回语句(ReturnStatement {
        value: Some(Box::new(value)),
        span: Default::default(),
    }),
    "返回" <value:Expr> "；" => AstNode::返回语句(ReturnStatement {
        value: Some(Box::new(value)),
        span: Default::default(),
    }),
    "返回" ";" => AstNode::返回语句(ReturnStatement {
        value: None,
        span: Default::default(),
    }),
    "返回" "；" => AstNode::返回语句(ReturnStatement {
        value: None,
        span: Default::default(),
    }),
};

BreakStatement: AstNode = {
    "跳出" ";" => AstNode::跳出语句(BreakStatement {
        span: Default::default(),
    }),
    "跳出" "；" => AstNode::跳出语句(BreakStatement {
        span: Default::default(),
    }),
};

ContinueStatement: AstNode = {
    "继续" ";" => AstNode::继续语句(ContinueStatement {
        span: Default::default(),
    }),
    "继续" "；" => AstNode::继续语句(ContinueStatement {
        span: Default::default(),
    }),
};

Block: Vec<AstNode> = {
    "{" <statements:Statement*> "}" => statements,
    "【" <statements:Statement*> "】" => statements
};

IfStatement: AstNode = {
    IfWithElse,
    IfWithoutElse,
};

// If statements with else (higher precedence to resolve dangling-else)
IfWithElse: AstNode = {
    "如果" <condition:Expr> <then_branch:Block> "否则" <else_branch:Block> => {
        AstNode::如果语句(IfStatement {
            condition: Box::new(condition),
            then_branch,
            else_branch: Some(Box::new(AstNode::块语句(BlockStatement {
                statements: else_branch,
                span: Default::default(),
            }))),
            span: Default::default(),
        })
    },
    "如果" <condition:Expr> <then_branch:Block> "否则如果" <else_if:IfWithElse> => {
        AstNode::如果语句(IfStatement {
            condition: Box::new(condition),
            then_branch,
            else_branch: Some(Box::new(else_if)),
            span: Default::default(),
        })
    },
};

// If statements without else
IfWithoutElse: AstNode = {
    "如果" <condition:Expr> <then_branch:Block> => {
        AstNode::如果语句(IfStatement {
            condition: Box::new(condition),
            then_branch,
            else_branch: None,
            span: Default::default(),
        })
    },
};

WhileStatement: AstNode = {
    "当" <condition:Expr> <body:Block> => AstNode::当语句(WhileStatement {
        condition: Box::new(condition),
        body,
        span: Default::default(),
    }),
};

ForStatement: AstNode = {
    "对于" <variable:Identifier> "在" <range:Expr> <body:Block> => AstNode::对于语句(ForStatement {
        variable,
        range: Box::new(range),
        body,
        span: Default::default(),
    }),
};

// ===== 新增语言特性语法规则 | New Language Features Grammar Rules =====

// 内联函数声明
InlineFunctionDeclaration: AstNode = {
    <vis:Visibility> "内联" "函数" <name:Identifier> "(" ")" ":" <return_type:Type> "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: vec![],
        return_type: Some(return_type),
        body,
        visibility: vis,
        is_inline: true,
        span: Default::default(),
    }),
    <vis:Visibility> "内联" "函数" <name:Identifier> "(" ")" "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: vec![],
        return_type: None,
        body,
        visibility: vis,
        is_inline: true,
        span: Default::default(),
    }),
    <vis:Visibility> "内联" "函数" <name:Identifier> "(" <params:ParameterList> ")" ":" <return_type:Type> "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: params,
        return_type: Some(return_type),
        body,
        visibility: vis,
        is_inline: true,
        span: Default::default(),
    }),
    <vis:Visibility> "内联" "函数" <name:Identifier> "(" <params:ParameterList> ")" "{" <body:Statement*> "}" => AstNode::函数声明(FunctionDeclaration {
        name,
        parameters: params,
        return_type: None,
        body,
        visibility: vis,
        is_inline: true,
        span: Default::default(),
    }),
};

// 联合体声明
UnionDeclaration: AstNode = {
    <vis:Visibility> "联合体" <name:Identifier> "{" <variants:UnionVariantList> "}" => AstNode::联合体声明(UnionDeclaration {
        name,
        variants,
        visibility: vis,
        span: Default::default(),
    }),
    <vis:Visibility> "联合体" <name:Identifier> "{" "}" => AstNode::联合体声明(UnionDeclaration {
        name,
        variants: vec![],
        visibility: vis,
        span: Default::default(),
    }),
};

UnionVariantList: Vec<UnionVariant> = {
    <variants:SemiSeparated<UnionVariant>> => variants,
};

UnionVariant: UnionVariant = {
    <type_annotation:Type> <name:Identifier> => UnionVariant {
        name,
        type_annotation,
        span: Default::default(),
    },
};

// 尝试/捕获/最终 语句
TryStatement: AstNode = {
    "尝试" <try_body:Block> <catch_clauses:CatchClause+> => AstNode::尝试语句(TryStatement {
        try_body,
        catch_clauses,
        finally_body: None,
        span: Default::default(),
    }),
    "尝试" <try_body:Block> <catch_clauses:CatchClause+> "最终" <finally_body:Block> => AstNode::尝试语句(TryStatement {
        try_body,
        catch_clauses,
        finally_body: Some(finally_body),
        span: Default::default(),
    }),
    "尝试" <try_body:Block> "最终" <finally_body:Block> => AstNode::尝试语句(TryStatement {
        try_body,
        catch_clauses: vec![],
        finally_body: Some(finally_body),
        span: Default::default(),
    }),
};

CatchClause: CatchClause = {
    // 捕获 错误变量 : 错误类型 { ... }
    "捕获" <error_var:Identifier> ":" <error_type:Type> <body:Block> => CatchClause {
        error_var: Some(error_var),
        error_type: Some(error_type),
        body,
        span: Default::default(),
    },
    // 捕获 错误变量 { ... }
    "捕获" <error_var:Identifier> <body:Block> => CatchClause {
        error_var: Some(error_var),
        error_type: None,
        body,
        span: Default::default(),
    },
    // 捕获 { ... }
    "捕获" <body:Block> => CatchClause {
        error_var: None,
        error_type: None,
        body,
        span: Default::default(),
    },
};

// 抛出语句
ThrowStatement: AstNode = {
    "抛出" <expression:Expr> ";" => AstNode::抛出语句(ThrowStatement {
        expression: Box::new(expression),
        span: Default::default(),
    }),
    "抛出" <expression:Expr> "；" => AstNode::抛出语句(ThrowStatement {
        expression: Box::new(expression),
        span: Default::default(),
    }),
};



TypeDeclaration: AstNode = {
    <vis:Visibility> "类型" <name:Identifier> "{" <fields:StructFieldList> "}" => AstNode::结构体声明(StructDeclaration {
        name,
        fields,
        methods: vec![],
        visibility: vis,
        span: Default::default(),
    }),
    <vis:Visibility> "类型" <name:Identifier> "{" "}" => AstNode::结构体声明(StructDeclaration {
        name,
        fields: vec![],
        methods: vec![],
        visibility: vis,
        span: Default::default(),
    }),
};

// 特性声明: 特性 名称 { 方法签名... }
TraitDeclaration: AstNode = {
    <vis:Visibility> "特性" <name:Identifier> "{" <methods:TraitMethodList> "}" => AstNode::特性声明(TraitDeclaration {
        name,
        methods,
        visibility: vis,
        span: Default::default(),
    }),
    <vis:Visibility> "特性" <name:Identifier> "{" "}" => AstNode::特性声明(TraitDeclaration {
        name,
        methods: vec![],
        visibility: vis,
        span: Default::default(),
    }),
};

TraitMethodList: Vec<TraitMethod> = {
    <methods:TraitMethod+> => methods,
};

// 特性方法签名: 函数 名称(参数) : 返回类型;
TraitMethod: TraitMethod = {
    "函数" <name:Identifier> "(" ")" ":" <return_type:Type> ";" => TraitMethod {
        name,
        parameters: vec![],
        return_type: Some(return_type),
        has_default_impl: false,
        default_body: None,
        span: Default::default(),
    },
    "函数" <name:Identifier> "(" <params:ParameterList> ")" ":" <return_type:Type> ";" => TraitMethod {
        name,
        parameters: params,
        return_type: Some(return_type),
        has_default_impl: false,
        default_body: None,
        span: Default::default(),
    },
    "函数" <name:Identifier> "(" ")" ";" => TraitMethod {
        name,
        parameters: vec![],
        return_type: None,
        has_default_impl: false,
        default_body: None,
        span: Default::default(),
    },
    "函数" <name:Identifier> "(" <params:ParameterList> ")" ";" => TraitMethod {
        name,
        parameters: params,
        return_type: None,
        has_default_impl: false,
        default_body: None,
        span: Default::default(),
    },
};

// 实现块: 实现 特性 对于 类型 { 方法... } 或 实现 类型 { 方法... }
ImplementationBlock: AstNode = {
    // 实现特性: 实现 特性名 对于 类型名 { ... }
    "实现" <trait_name:Identifier> "对于" <target_type:Identifier> "{" <methods:ImplMethodList> "}" => AstNode::实现块(ImplementationBlock {
        trait_name: Some(trait_name),
        target_type,
        methods,
        span: Default::default(),
    }),
    "实现" <trait_name:Identifier> "对于" <target_type:Identifier> "{" "}" => AstNode::实现块(ImplementationBlock {
        trait_name: Some(trait_name),
        target_type,
        methods: vec![],
        span: Default::default(),
    }),
    // 直接实现: 实现 类型名 { ... }
    "实现" <target_type:Identifier> "{" <methods:ImplMethodList> "}" => AstNode::实现块(ImplementationBlock {
        trait_name: None,
        target_type,
        methods,
        span: Default::default(),
    }),
    "实现" <target_type:Identifier> "{" "}" => AstNode::实现块(ImplementationBlock {
        trait_name: None,
        target_type,
        methods: vec![],
        span: Default::default(),
    }),
};

ImplMethodList: Vec<MethodDeclaration> = {
    <methods:ImplMethod+> => methods,
};

// 实现块中的方法
ImplMethod: MethodDeclaration = {
    "函数" <name:Identifier> "(" ")" ":" <return_type:Type> "{" <body:Statement*> "}" => MethodDeclaration {
        receiver_name: "自己".to_string(),
        receiver_type: String::new(),  // Will be filled from context
        is_receiver_mutable: false,
