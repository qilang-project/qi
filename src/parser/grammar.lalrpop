        body,
        visibility: Visibility::公开,
        span: Default::default(),
    },
    "函数" <name:Identifier> "(" ")" "{" <body:Statement*> "}" => MethodDeclaration {
        receiver_name: "自己".to_string(),
        receiver_type: String::new(),
        is_receiver_mutable: false,
        method_name: name,
        parameters: vec![],
        return_type: None,
        body,
        visibility: Visibility::公开,
        span: Default::default(),
    },
    "函数" <name:Identifier> "(" <params:ParameterList> ")" "{" <body:Statement*> "}" => MethodDeclaration {
        receiver_name: "自己".to_string(),
        receiver_type: String::new(),
        is_receiver_mutable: false,
        method_name: name,
        parameters: params,
        return_type: None,
        body,
        visibility: Visibility::公开,
        span: Default::default(),
    },
};

StructFieldList: Vec<StructField> = {
    <fields:SemiSeparated<StructField>> => fields,
};

StructField: StructField = {
    <vis:Visibility> <type_annotation:Type> <name:Identifier> => StructField {
        name,
        type_annotation,
        is_embedded: false,
        visibility: vis,
        span: Default::default(),
    },
};


SelectCaseList: Vec<SelectCase> = {
    <cases:SelectCase+> => cases,
};

SelectCase: SelectCase = {
    // Send case must come first: 情况 channel <- value:
    // This has higher priority to avoid ambiguity
    "情况" <channel:ChannelExpr> "<-" <value:Expr> ":" <body:StatementList> => SelectCase {
        kind: SelectCaseKind::通道发送 {
            channel: Box::new(channel),
            value: Box::new(value),
        },
        body,
        span: Default::default(),
    },
    
    // Receive case with variable: 情况 variable := <-channel:
    "情况" <var:Identifier> ":=" "<-" <channel:Expr> ":" <body:StatementList> => SelectCase {
        kind: SelectCaseKind::通道接收 {
            channel: Box::new(channel),
            variable: Some(var),
        },
        body,
        span: Default::default(),
    },
    
    // Receive case without variable: 情况 <-channel:
    "情况" "<-" <channel:Expr> ":" <body:StatementList> => SelectCase {
        kind: SelectCaseKind::通道接收 {
            channel: Box::new(channel),
            variable: None,
        },
        body,
        span: Default::default(),
    },
};

// Channel expression (no arrow operator to avoid conflicts)
ChannelExpr: AstNode = {
    Primary,
};

DefaultCase: SelectCase = {
    "默认" ":" <body:StatementList> => SelectCase {
        kind: SelectCaseKind::默认,
        body,
        span: Default::default(),
    },
};

StatementList: Vec<AstNode> = {
    <stmts:Statement*> => stmts,
};

// Expression hierarchy using tiered approach like Solang
// Each level handles operators of the same precedence
Expr: AstNode = {
    Precedence1,
};

// Level 1: Assignment (lowest precedence, right-associative)
// Only Precedence8 (postfix) expressions can be assigned to (identifiers, field access, array subscript)
Precedence1: AstNode = {
    // Compound assignment operators (desugar to binary operation + assignment)
    <left:Precedence8> "+=" <right:Precedence1> => {
        match &left {
            AstNode::标识符表达式(_) | AstNode::字段访问表达式(_) | AstNode::数组访问表达式(_) => {
                AstNode::赋值表达式(AssignmentExpression {
                    target: Box::new(left.clone()),
                    value: Box::new(AstNode::二元操作表达式(BinaryExpression {
                        left: Box::new(left),
                        operator: BinaryOperator::加,
                        right: Box::new(right),
                        span: Default::default(),
                    })),
                    span: Default::default(),
                })
            },
            _ => panic!("Invalid assignment target")
        }
    },
    <left:Precedence8> "-=" <right:Precedence1> => {
        match &left {
            AstNode::标识符表达式(_) | AstNode::字段访问表达式(_) | AstNode::数组访问表达式(_) => {
                AstNode::赋值表达式(AssignmentExpression {
                    target: Box::new(left.clone()),
                    value: Box::new(AstNode::二元操作表达式(BinaryExpression {
                        left: Box::new(left),
                        operator: BinaryOperator::减,
                        right: Box::new(right),
                        span: Default::default(),
                    })),
                    span: Default::default(),
                })
            },
            _ => panic!("Invalid assignment target")
        }
    },
    <left:Precedence8> "*=" <right:Precedence1> => {
        match &left {
            AstNode::标识符表达式(_) | AstNode::字段访问表达式(_) | AstNode::数组访问表达式(_) => {
                AstNode::赋值表达式(AssignmentExpression {
                    target: Box::new(left.clone()),
                    value: Box::new(AstNode::二元操作表达式(BinaryExpression {
                        left: Box::new(left),
                        operator: BinaryOperator::乘,
                        right: Box::new(right),
                        span: Default::default(),
                    })),
                    span: Default::default(),
                })
            },
            _ => panic!("Invalid assignment target")
        }
    },
    <left:Precedence8> "/=" <right:Precedence1> => {
        match &left {
            AstNode::标识符表达式(_) | AstNode::字段访问表达式(_) | AstNode::数组访问表达式(_) => {
                AstNode::赋值表达式(AssignmentExpression {
                    target: Box::new(left.clone()),
                    value: Box::new(AstNode::二元操作表达式(BinaryExpression {
                        left: Box::new(left),
                        operator: BinaryOperator::除,
                        right: Box::new(right),
                        span: Default::default(),
                    })),
                    span: Default::default(),
                })
            },
            _ => panic!("Invalid assignment target")
        }
    },
    <left:Precedence8> "%=" <right:Precedence1> => {
        match &left {
            AstNode::标识符表达式(_) | AstNode::字段访问表达式(_) | AstNode::数组访问表达式(_) => {
                AstNode::赋值表达式(AssignmentExpression {
                    target: Box::new(left.clone()),
                    value: Box::new(AstNode::二元操作表达式(BinaryExpression {
                        left: Box::new(left),
                        operator: BinaryOperator::取余,
                        right: Box::new(right),
                        span: Default::default(),
                    })),
                    span: Default::default(),
                })
            },
            _ => panic!("Invalid assignment target")
        }
    },

    // Regular assignment
    <left:Precedence8> "=" <right:Precedence1> => {
        // Validate that left is a valid LValue
        match &left {
            AstNode::标识符表达式(_) |
            AstNode::字段访问表达式(_) |
            AstNode::数组访问表达式(_) => {
                AstNode::赋值表达式(AssignmentExpression {
                    target: Box::new(left),
                    value: Box::new(right),
                    span: Default::default(),
                })
            },
            _ => panic!("Invalid assignment target: only identifiers, field access, and array subscript are allowed")
        }
    },
    <channel:Precedence8> "<-" <value:Precedence1> => AstNode::通道发送表达式(ChannelSendExpression {
        channel: Box::new(channel),
        value: Box::new(value),
        span: Default::default(),
    }),
    Precedence2,
};

// Level 2: Logical OR
Precedence2: AstNode = {
    <left:Precedence2> "或" <right:Precedence3> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::或,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence2> "||" <right:Precedence3> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::或,
        right: Box::new(right),
        span: Default::default(),
    }),
    Precedence3,
};

// Level 3: Logical AND
Precedence3: AstNode = {
    <left:Precedence3> "与" <right:Precedence4> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::与,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence3> "&&" <right:Precedence4> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::与,
        right: Box::new(right),
        span: Default::default(),
    }),
    Precedence4,
};

// Level 4: Comparison operators
Precedence4: AstNode = {
    <left:Precedence5> "==" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "等于" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "!=" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::不等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "不等于" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::不等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> ">" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::大于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "大于" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::大于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> ">=" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::大于等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "大于等于" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::大于等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "<" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::小于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "小于" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::小于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "<=" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::小于等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5> "小于等于" <right:Precedence5> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::小于等于,
        right: Box::new(right),
        span: Default::default(),
    }),
    Precedence5,
};

// Level 5: Type conversion (作为)
Precedence5: AstNode = {
    <expr:Precedence5_5> "作为" <target_type:Type> => AstNode::类型转换表达式(TypeCastExpression {
        expression: Box::new(expr),
        target_type,
        span: Default::default(),
    }),
    Precedence5_5,
};

// Level 5.5: Addition and subtraction
Precedence5_5: AstNode = {
    <left:Precedence5_5> "+" <right:Precedence6> => {
        // Check if both operands are strings - if so, create StringConcatExpression
        let is_string_concat = match (&left, &right) {
            (AstNode::字面量表达式(lit_left), AstNode::字面量表达式(lit_right)) => {
                matches!(&lit_left.value, LiteralValue::字符串(_)) &&
                matches!(&lit_right.value, LiteralValue::字符串(_))
            },
            (AstNode::字面量表达式(lit), _) => matches!(&lit.value, LiteralValue::字符串(_)),
            (_, AstNode::字面量表达式(lit)) => matches!(&lit.value, LiteralValue::字符串(_)),
            _ => false,
        };

        if is_string_concat {
            AstNode::字符串连接表达式(StringConcatExpression {
                left: Box::new(left),
                right: Box::new(right),
                span: Default::default(),
            })
        } else {
            AstNode::二元操作表达式(BinaryExpression {
                left: Box::new(left),
                operator: BinaryOperator::加,
                right: Box::new(right),
                span: Default::default(),
            })
        }
    },
    <left:Precedence5_5> "加" <right:Precedence6> => {
        // Check if both operands are strings - if so, create StringConcatExpression
        let is_string_concat = match (&left, &right) {
            (AstNode::字面量表达式(lit_left), AstNode::字面量表达式(lit_right)) => {
                matches!(&lit_left.value, LiteralValue::字符串(_)) &&
                matches!(&lit_right.value, LiteralValue::字符串(_))
            },
            (AstNode::字面量表达式(lit), _) => matches!(&lit.value, LiteralValue::字符串(_)),
            (_, AstNode::字面量表达式(lit)) => matches!(&lit.value, LiteralValue::字符串(_)),
            _ => false,
        };

        if is_string_concat {
            AstNode::字符串连接表达式(StringConcatExpression {
                left: Box::new(left),
                right: Box::new(right),
                span: Default::default(),
            })
        } else {
            AstNode::二元操作表达式(BinaryExpression {
                left: Box::new(left),
                operator: BinaryOperator::加,
                right: Box::new(right),
                span: Default::default(),
            })
        }
    },
    <left:Precedence5_5> "-" <right:Precedence6> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::减,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence5_5> "减" <right:Precedence6> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::减,
        right: Box::new(right),
        span: Default::default(),
    }),
    Precedence6,
};

// Level 6: Multiplication, division, and modulo
Precedence6: AstNode = {
    <left:Precedence6> "*" <right:Precedence7> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::乘,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence6> "乘" <right:Precedence7> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::乘,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence6> "/" <right:Precedence7> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::除,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence6> "除" <right:Precedence7> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::除,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence6> "%" <right:Precedence7> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::取余,
        right: Box::new(right),
        span: Default::default(),
    }),
    <left:Precedence6> "取余" <right:Precedence7> => AstNode::二元操作表达式(BinaryExpression {
        left: Box::new(left),
        operator: BinaryOperator::取余,
        right: Box::new(right),
        span: Default::default(),
    }),
    Precedence7,
};

// Level 7: Unary operators
Precedence7: AstNode = {
    "等待" <expr:Precedence7> => AstNode::等待表达式(AwaitExpression {
        expression: Box::new(expr),
        span: Default::default(),
    }),
    "启动" <expr:Precedence7> => AstNode::协程启动表达式(GoroutineSpawnExpression {
        expression: Box::new(expr),
        span: Default::default(),
    }),
    "创建通道" "(" <element_type:Type> ")" => AstNode::通道创建表达式(ChannelCreateExpression {
        element_type,
        capacity: None,
        span: Default::default(),
    }),
    "创建通道" "(" <element_type:Type> "," <capacity:Precedence7> ")" => AstNode::通道创建表达式(ChannelCreateExpression {
        element_type,
        capacity: Some(Box::new(capacity)),
        span: Default::default(),
    }),
    "<-" <channel:Precedence7> => AstNode::通道接收表达式(ChannelReceiveExpression {
        channel: Box::new(channel),
        span: Default::default(),
    }),
    "-" <expr:Precedence7> => AstNode::一元操作表达式(UnaryExpression {
        operator: UnaryOperator::负,
        operand: Box::new(expr),
        span: Default::default(),
    }),
    "+" <expr:Precedence7> => AstNode::一元操作表达式(UnaryExpression {
        operator: UnaryOperator::正,
        operand: Box::new(expr),
        span: Default::default(),
    }),
    "!" <expr:Precedence7> => AstNode::一元操作表达式(UnaryExpression {
        operator: UnaryOperator::非,
        operand: Box::new(expr),
        span: Default::default(),
    }),
    "非" <expr:Precedence7> => AstNode::一元操作表达式(UnaryExpression {
        operator: UnaryOperator::非,
        operand: Box::new(expr),
        span: Default::default(),
    }),
    Precedence8,
};

// Level 8: Postfix operators (field access, array subscript, function call)
Precedence8: AstNode = {
    // Special handling for Future static methods since "未来" is a reserved keyword
    "未来" "::" <method:Identifier> "(" <args:ExprList> ")" => {
        // Future static method call: 未来::就绪(42)
        // Create a fake identifier for "未来" and treat as method call
        let type_ident = AstNode::标识符表达式(IdentifierExpression {
            name: "未来".to_string(),
            span: Default::default(),
        });
        AstNode::方法调用表达式(MethodCallExpression {
            object: Box::new(type_ident),
            method_name: format!("::{}", method),
            arguments: args,
            span: Default::default(),
        })
    },
    "未来" "::" <method:Identifier> "(" ")" => {
        // Future static method call with no args
        let type_ident = AstNode::标识符表达式(IdentifierExpression {
            name: "未来".to_string(),
            span: Default::default(),
        });
        AstNode::方法调用表达式(MethodCallExpression {
            object: Box::new(type_ident),
            method_name: format!("::{}", method),
            arguments: vec![],
            span: Default::default(),
        })
    },
    <base:Precedence8> "::" <method:Identifier> => {
        // Static method call: Type::method parsed as a field access for now
        // The codegen layer will convert this to the appropriate static method call
        AstNode::字段访问表达式(FieldAccessExpression {
            object: Box::new(base),
            field: format!("::{}",  method),  // Mark as static method with :: prefix
            span: Default::default(),
        })
    },
    <base:Precedence8> "." <field:Identifier> => {
        AstNode::字段访问表达式(FieldAccessExpression {
            object: Box::new(base),
            field,
            span: Default::default(),
        })
    },
    <base:Precedence8> "." "长度" => {
        AstNode::字段访问表达式(FieldAccessExpression {
            object: Box::new(base),
            field: "长度".to_string(),
            span: Default::default(),
        })
    },
    <array:Precedence8> "[" <index:Expr> "]" => {
        AstNode::数组访问表达式(ArrayAccessExpression {
            array: Box::new(array),
            index: Box::new(index),
            span: Default::default(),
        })
    },
    // 通道类型构造器：通道<类型>() or 通道<类型>(容量)
    <channel_type:ChannelTypeConstructor> "(" ")" => AstNode::通道创建表达式(ChannelCreateExpression {
        element_type: channel_type,
        capacity: None,
        span: Default::default(),
    }),
    <channel_type:ChannelTypeConstructor> "(" <capacity:Expr> ")" => AstNode::通道创建表达式(ChannelCreateExpression {
        element_type: channel_type,
        capacity: Some(Box::new(capacity)),
        span: Default::default(),
    }),
    <channel_type:ChannelTypeConstructor> "（" "）" => AstNode::通道创建表达式(ChannelCreateExpression {
        element_type: channel_type,
        capacity: None,
        span: Default::default(),
    }),
    <channel_type:ChannelTypeConstructor> "（" <capacity:Expr> "）" => AstNode::通道创建表达式(ChannelCreateExpression {
        element_type: channel_type,
        capacity: Some(Box::new(capacity)),
        span: Default::default(),
    }),
    <callee:Precedence8> "(" <args:ExprList> ")" => {
        match callee {
            AstNode::标识符表达式(ident) => AstNode::函数调用表达式(FunctionCallExpression {
                module_qualifier: None,
                callee: ident.name,
                arguments: args,
                span: Default::default(),
            }),
            AstNode::字段访问表达式(field_access) => {
                // 统一解析为方法调用，让 codegen 层根据上下文区分是模块调用还是方法调用
                AstNode::方法调用表达式(MethodCallExpression {
                    object: field_access.object,
                    method_name: field_access.field,
                    arguments: args,
                    span: Default::default(),
                })
            },
            _ => callee,
        }
    },
    <callee:Precedence8> "(" ")" => {
        match callee {
            AstNode::标识符表达式(ident) => AstNode::函数调用表达式(FunctionCallExpression {
                module_qualifier: None,
                callee: ident.name,
                arguments: vec![],
                span: Default::default(),
            }),
            AstNode::字段访问表达式(field_access) => {
                // 统一解析为方法调用，让 codegen 层根据上下文区分是模块调用还是方法调用
                AstNode::方法调用表达式(MethodCallExpression {
                    object: field_access.object,
                    method_name: field_access.field,
                    arguments: vec![],
                    span: Default::default(),
                })
            },
            _ => callee,
        }
    },
    // 中文括号版本
    <callee:Precedence8> "（" <args:ExprList> "）" => {
        match callee {
            AstNode::标识符表达式(ident) => AstNode::函数调用表达式(FunctionCallExpression {
                module_qualifier: None,
                callee: ident.name,
                arguments: args,
                span: Default::default(),
            }),
            AstNode::字段访问表达式(field_access) => {
                // 统一解析为方法调用，让 codegen 层根据上下文区分是模块调用还是方法调用
                AstNode::方法调用表达式(MethodCallExpression {
                    object: field_access.object,
                    method_name: field_access.field,
                    arguments: args,
                    span: Default::default(),
                })
            },
            _ => callee,
        }
    },
    <callee:Precedence8> "（" "）" => {
        match callee {
            AstNode::标识符表达式(ident) => AstNode::函数调用表达式(FunctionCallExpression {
                module_qualifier: None,
                callee: ident.name,
                arguments: vec![],
                span: Default::default(),
            }),
            AstNode::字段访问表达式(field_access) => {
                // 统一解析为方法调用，让 codegen 层根据上下文区分是模块调用还是方法调用
                AstNode::方法调用表达式(MethodCallExpression {
                    object: field_access.object,
                    method_name: field_access.field,
                    arguments: vec![],
                    span: Default::default(),
                })
            },
            _ => callee,
        }
    },
    UnaryPrefix,
};

// Unary prefix operators: 取地址 (address-of) and 解引用 (dereference)
UnaryPrefix: AstNode = {
    "取地址" <expr:UnaryPrefix> => AstNode::取地址表达式(AddressOfExpression {
        expression: Box::new(expr),
        span: Default::default(),
    }),
    "&" <expr:UnaryPrefix> => AstNode::取地址表达式(AddressOfExpression {
        expression: Box::new(expr),
        span: Default::default(),
    }),
    "解引用" <expr:UnaryPrefix> => AstNode::解引用表达式(DereferenceExpression {
        expression: Box::new(expr),
        span: Default::default(),
    }),
    "*" <expr:UnaryPrefix> => AstNode::解引用表达式(DereferenceExpression {
        expression: Box::new(expr),
        span: Default::default(),
    }),
    Primary,
};

// Primary expressions (literals, identifiers, parenthesized expressions)
// Note: Struct literals are parsed in Atom within parentheses to avoid ambiguity
// with blocks in control flow statements. To use struct literals as expressions,
// Struct literals require parentheses to avoid ambiguity with blocks
// Syntax: (结构体名 { 字段: 值 }) or （结构体名 { 字段: 值 }）
Primary: AstNode = {
    <name:Identifier> => AstNode::标识符表达式(IdentifierExpression {
        name,
        span: Default::default(),
    }),
    Atom,
};

// Atomic expressions - the lowest level
// Struct literals can use: 新建 结构体名 { 字段: 值 } or parentheses for backwards compatibility
Atom: AstNode = {
    BooleanLiteral,
    IntegerLiteral,
    FloatLiteral,
    StringLiteral,
    CharLiteral,
    ArrayLiteral,
    ClosureExpression,
    MatchExpression,
    AsyncBlockExpression,
    // Parenthesized expressions
    "(" <Expr> ")",
    "（" <Expr> "）",
    // Struct literals with 新建 keyword (preferred syntax)
    "新建" <name:Identifier> "{" <fields:StructFieldValueList> "}" => AstNode::结构体实例化表达式(StructLiteralExpression {
        struct_name: name,
        fields,
        span: Default::default(),
    }),
    "新建" <name:Identifier> "{" "}" => AstNode::结构体实例化表达式(StructLiteralExpression {
        struct_name: name,
        fields: vec![],
        span: Default::default(),
    }),
    // Struct literals with parentheses (backwards compatible syntax)
    "(" <name:Identifier> "{" <fields:StructFieldValueList> "}" ")" => AstNode::结构体实例化表达式(StructLiteralExpression {
        struct_name: name,
        fields,
        span: Default::default(),
    }),
    "(" <name:Identifier> "{" "}" ")" => AstNode::结构体实例化表达式(StructLiteralExpression {
        struct_name: name,
        fields: vec![],
        span: Default::default(),
    }),
    "（" <name:Identifier> "{" <fields:StructFieldValueList> "}" "）" => AstNode::结构体实例化表达式(StructLiteralExpression {
        struct_name: name,
        fields,
        span: Default::default(),
    }),
    "（" <name:Identifier> "{" "}" "）" => AstNode::结构体实例化表达式(StructLiteralExpression {
        struct_name: name,
        fields: vec![],
        span: Default::default(),
    }),
};

// 闭包表达式: 闭包 (参数列表) : 返回类型 { 函数体 }
ClosureExpression: AstNode = {
    "闭包" "(" <params:ParameterList> ")" ":" <return_type:Type> <body:Block> => AstNode::闭包表达式(ClosureExpression {
        parameters: params,
        return_type: Some(return_type),
        body,
        captures: vec![],
        span: Default::default(),
    }),
    "闭包" "(" <params:ParameterList> ")" <body:Block> => AstNode::闭包表达式(ClosureExpression {
        parameters: params,
        return_type: None,
        body,
        captures: vec![],
        span: Default::default(),
    }),
    "闭包" "(" ")" ":" <return_type:Type> <body:Block> => AstNode::闭包表达式(ClosureExpression {
        parameters: vec![],
        return_type: Some(return_type),
        body,
        captures: vec![],
        span: Default::default(),
    }),
    "闭包" "(" ")" <body:Block> => AstNode::闭包表达式(ClosureExpression {
        parameters: vec![],
        return_type: None,
        body,
        captures: vec![],
        span: Default::default(),
    }),
    // 简化语法: |参数| 表达式
    "|" <params:ParameterList> "|" <body:Block> => AstNode::闭包表达式(ClosureExpression {
        parameters: params,
        return_type: None,
        body,
        captures: vec![],
        span: Default::default(),
    }),
    "|" "|" <body:Block> => AstNode::闭包表达式(ClosureExpression {
        parameters: vec![],
        return_type: None,
        body,
        captures: vec![],
        span: Default::default(),
    }),
};

// 匹配表达式: 匹配 值 { 分支... }
MatchExpression: AstNode = {
    "匹配" <value:Expr> "{" <arms:MatchArmList> "}" => AstNode::匹配表达式(MatchExpression {
        value: Box::new(value),
        arms,
        span: Default::default(),
    }),
};

MatchArmList: Vec<MatchArm> = {
    <arms:MatchArm+> => arms,
};

MatchArm: MatchArm = {
    // 模式 => { 语句块 }
    <pattern:MatchPattern> "=>" <body:Block> => MatchArm {
        pattern,
        guard: None,
        body,
        span: Default::default(),
    },
    // 模式 如果 守卫条件 => { 语句块 }
    <pattern:MatchPattern> "如果" <guard:Expr> "=>" <body:Block> => MatchArm {
        pattern,
        guard: Some(Box::new(guard)),
        body,
        span: Default::default(),
    },
    // 模式 => 表达式;
    <pattern:MatchPattern> "=>" <expr:Expr> ";" => MatchArm {
        pattern,
        guard: None,
        body: vec![AstNode::表达式语句(ExpressionStatement {
            expression: Box::new(expr),
            span: Default::default(),
        })],
        span: Default::default(),
    },
    // 模式 => 表达式；
    <pattern:MatchPattern> "=>" <expr:Expr> "；" => MatchArm {
        pattern,
        guard: None,
        body: vec![AstNode::表达式语句(ExpressionStatement {
            expression: Box::new(expr),
            span: Default::default(),
        })],
        span: Default::default(),
    },
    // 模式 => 表达式,
    <pattern:MatchPattern> "=>" <expr:Expr> "," => MatchArm {
        pattern,
        guard: None,
        body: vec![AstNode::表达式语句(ExpressionStatement {
            expression: Box::new(expr),
            span: Default::default(),
        })],
        span: Default::default(),
    },
};

MatchPattern: MatchPattern = {
    // 简单模式（通配符、字面量、变量绑定）
    MatchPatternAtom,
    // 或模式: 模式1 | 模式2
    <first:MatchPatternAtom> "|" <rest:MatchPatternOrList> => {
        let mut patterns = vec![first];
        patterns.extend(rest);
        MatchPattern::或模式(patterns)
    },
};

MatchPatternAtom: MatchPattern = {
    "_" => MatchPattern::通配符,
    <n:r"[0-9]+"> => MatchPattern::字面量(LiteralValue::整数(n.parse().unwrap())),
    <n:r"[0-9]+\.[0-9]+"> => MatchPattern::字面量(LiteralValue::浮点数(n.parse().unwrap())),
    <s:r#""[^"]*""#> => MatchPattern::字面量(LiteralValue::字符串(s[1..s.len()-1].to_string())),
    "真" => MatchPattern::字面量(LiteralValue::布尔(true)),
    "假" => MatchPattern::字面量(LiteralValue::布尔(false)),
    <name:Identifier> => MatchPattern::变量绑定(name),
};

MatchPatternOrList: Vec<MatchPattern> = {
    <first:MatchPatternAtom> => vec![first],
    <first:MatchPatternAtom> "|" <rest:MatchPatternOrList> => {
        let mut patterns = vec![first];
        patterns.extend(rest);
        patterns
    },
};

// 异步块表达式: 异步 { ... }
AsyncBlockExpression: AstNode = {
    "异步" <body:Block> => AstNode::异步块表达式(AsyncBlockExpression {
        body,
        span: Default::default(),
    }),
};

BooleanLiteral: AstNode = {
    "真" => AstNode::字面量表达式(LiteralExpression {
        value: LiteralValue::布尔(true),
        span: Default::default(),
    }),
    "假" => AstNode::字面量表达式(LiteralExpression {
        value: LiteralValue::布尔(false),
        span: Default::default(),
    }),
};

IntegerLiteral: AstNode = {
    <n:r"[0-9]+"> => AstNode::字面量表达式(LiteralExpression {
        value: LiteralValue::整数(n.parse().unwrap()),
        span: Default::default(),
    }),
};

FloatLiteral: AstNode = {
    <n:r"[0-9]+\.[0-9]+"> => AstNode::字面量表达式(LiteralExpression {
        value: LiteralValue::浮点数(n.parse().unwrap()),
        span: Default::default(),
    }),
};

StringLiteral: AstNode = {
    <s:r#""([^"\\]|\\.)*""#> => AstNode::字面量表达式(LiteralExpression {
        value: LiteralValue::字符串(unescape_string(&s[1..s.len()-1])),
        span: Default::default(),
    }),
};

CharLiteral: AstNode = {
    <c:r"'.'"> => AstNode::字面量表达式(LiteralExpression {
        value: LiteralValue::字符(c.chars().nth(1).unwrap()),
        span: Default::default(),
    }),
};

ArrayLiteral: AstNode = {
    "[" <elements:ExprList> "]" => AstNode::数组字面量表达式(ArrayLiteralExpression {
        elements,
        span: Default::default(),
    }),
    "[" "]" => AstNode::数组字面量表达式(ArrayLiteralExpression {
        elements: vec![],
        span: Default::default(),
    }),
};


StructFieldValueList: Vec<StructFieldValue> = {
    <fields:Comma<StructFieldValue>> => fields,
};

StructFieldValue: StructFieldValue = {
    <name:Identifier> ":" <value:Expr> => StructFieldValue {
        name,
        value: Box::new(value),
        span: Default::default(),
    },
};

ParameterList: Vec<Parameter> = {
    <params:Comma<Parameter>> => params,
};

Parameter: Parameter = {
    // Fix syntax - use proper colon token
    <name:Identifier> ":" <type_annotation:Type> => Parameter {
        name,
        type_annotation: Some(type_annotation),
        span: Default::default(),
    },
    <name:Identifier> "：" <type_annotation:Type> => Parameter {
        name,
        type_annotation: Some(type_annotation),
        span: Default::default(),
    },
    <name:Identifier> => Parameter {
        name,
        type_annotation: None,
        span: Default::default(),
    },
};

// Helper macro for comma-separated lists
Comma<T>: Vec<T> = {
    <first:T> => vec![first],
    <first:T> "," <rest:Comma<T>> => {
        let mut rest = rest;
        rest.insert(0, first);
        rest
    },
    <first:T> "，" <rest:Comma<T>> => {
        let mut rest = rest;
        rest.insert(0, first);
        rest
    },
};

// Helper macro for semicolon-separated lists
SemiSeparated<T>: Vec<T> = {
    <first:T> ";" => vec![first],
    <first:T> ";" <rest:SemiSeparated<T>> => {
        let mut rest = rest;
        rest.insert(0, first);
        rest
    },
    <first:T> "；" => vec![first],
    <first:T> "；" <rest:SemiSeparated<T>> => {
        let mut rest = rest;
        rest.insert(0, first);
        rest
    }
};

ExprList: Vec<AstNode> = {
    <exprs:Comma<Expr>> => exprs,
};

Type: TypeNode = {
    // 容器类型 - 使用特殊语法避免冲突
    "数组" "<" <element_type:Type> ">" => TypeNode::数组类型(ArrayType {
        element_type: Box::new(element_type),
        size: None,
    }),
    "字典" "<" <key_type:Type> "," <value_type:Type> ">" => TypeNode::字典类型(DictionaryType {
        key_type: Box::new(key_type),
        value_type: Box::new(value_type),
    }),
    "列表" "<" <element_type:Type> ">" => TypeNode::列表类型(ListType {
        element_type: Box::new(element_type),
    }),
    "通道" "<" <element_type:Type> ">" => TypeNode::通道类型(ChannelType {
        element_type: Box::new(element_type),
    }),
    "集合" "<" <element_type:Type> ">" => TypeNode::集合类型(SetType {
        element_type: Box::new(element_type),
    }),

    // 未来类型 (Future type for async operations)
    "未来" "<" <inner_type:Type> ">" => TypeNode::未来类型(Box::new(inner_type)),

    // 结果类型 (Result type for error handling)
    "结果" "<" <ok_type:Type> "," <err_type:Type> ">" => TypeNode::结果类型(ResultType {
        ok_type: Box::new(ok_type),
        err_type: Box::new(err_type),
    }),

    // 选项类型 (Option type for nullable values)
    "选项" "<" <inner_type:Type> ">" => TypeNode::选项类型(OptionType {
        inner_type: Box::new(inner_type),
    }),

    // 指针和引用类型
    "指针" "<" <target_type:Type> ">" => TypeNode::指针类型(PointerType {
        target_type: Box::new(target_type),
    }),
    "引用" "<" <target_type:Type> ">" => TypeNode::引用类型(ReferenceType {
        target_type: Box::new(target_type),
        is_mutable: false,
    }),
    "可变引用" "<" <target_type:Type> ">" => TypeNode::引用类型(ReferenceType {
        target_type: Box::new(target_type),
        is_mutable: true,
    }),

    // 基础类型 - 使用关键字而不是标识符
    BasicTypeKeyword,

    // 自定义类型 (struct names, etc.) - 使用TypeName避免冲突
    <name:TypeName> => TypeNode::自定义类型(name),
};

// 用于类型名称的标识符，避免与其他Identifier冲突
TypeName: String = {
    <id:r"[a-zA-Z_][\u4e00-\u9fffa-zA-Z0-9_]*"> => id.to_string(),
    <id:r"[\u4e00-\u9fff][\u4e00-\u9fffa-zA-Z0-9_]*"> => {
        // Simplified check - use individual checks to avoid long match patterns
        if id == "变量" || id == "常量" || id == "函数" || id == "异步" || id == "返回" ||
           id == "如果" || id == "否则" || id == "当" || id == "对于" || id == "在" || id == "真" || id == "假" ||
           id == "等待" || id == "循环" || id == "包" || id == "导入" || id == "导出" || id == "作为" ||
           id == "公开" || id == "私有" || id == "模块" || id == "自己" ||
           id == "枚举" || id == "实现" || id == "特性" ||
           id == "等于" || id == "不等于" || id == "大于" || id == "小于" || id == "大于等于" || id == "小于等于" ||
           id == "取余" || id == "加" || id == "减" || id == "乘" || id == "除" {
            panic!("Keyword used as type name: {}", id);
        }
        id.to_string()
    }
};

// 基础类型关键字解析
BasicTypeKeyword: TypeNode = {
    "整数" => TypeNode::基础类型(BasicType::整数),
    "长整数" => TypeNode::基础类型(BasicType::长整数),
    "短整数" => TypeNode::基础类型(BasicType::短整数),
    "字节" => TypeNode::基础类型(BasicType::字节),
    "浮点数" => TypeNode::基础类型(BasicType::浮点数),
    "布尔" => TypeNode::基础类型(BasicType::布尔),
    "字符" => TypeNode::基础类型(BasicType::字符),
    "字符串" => TypeNode::基础类型(BasicType::字符串),
    "空" => TypeNode::基础类型(BasicType::空),
};

Identifier: String = {
    <id:r"[a-zA-Z_][\u4e00-\u9fffa-zA-Z0-9_]*"> => id.to_string(),
    <id:r"[\u4e00-\u9fff][\u4e00-\u9fffa-zA-Z0-9_]*"> => {
        // Check if it's a forbidden keyword using individual checks
        // Note: 自身, 自己, 自我 are allowed as they are used for method receivers
        if id == "变量" || id == "常量" || id == "函数" || id == "异步" || id == "返回" ||
           id == "如果" || id == "否则" || id == "当" || id == "对于" || id == "在" || id == "真" || id == "假" ||
           id == "等待" || id == "循环" || id == "中断" || id == "继续" || id == "匹配" || id == "跳转" ||
           id == "抛出" || id == "捕获" || id == "尝试" || id == "选项" ||
           id == "拥有" || id == "借用" || id == "移动" || id == "克隆" || id == "释放" || id == "新建" ||
           id == "并行" || id == "并发" || id == "任务" || id == "启动" || id == "线程" || id == "锁" || id == "原子" ||
           id == "通道" || id == "选择" || id == "情况" || id == "未来" ||
           id == "长度" || id == "输入" || id == "包" || id == "导入" ||
           id == "导出" || id == "作为" || id == "公开" || id == "私有" || id == "模块" ||
           id == "方法" || id == "枚举" ||
           id == "联合体" || id == "实现" || id == "特性" || id == "主程序入口" ||
           id == "等于" || id == "不等于" || id == "大于" || id == "小于" || id == "大于等于" || id == "小于等于" ||
           id == "取余" || id == "加" || id == "减" || id == "乘" || id == "除" {
            panic!("Keyword used as identifier: {}", id);
        }
        id.to_string()
    },
};

// 方法接收者标识符 - 允许使用 "自身"、"自己" 等关键字
ReceiverIdentifier: String = {
    <id:r"[a-zA-Z_][\u4e00-\u9fffa-zA-Z0-9_]*"> => id.to_string(),
    <id:r"[\u4e00-\u9fff][\u4e00-\u9fffa-zA-Z0-9_]*"> => {
        // Allow 自身, 自己, 自我 as receiver names
        // Still forbid other keywords
        if id == "变量" || id == "常量" || id == "函数" || id == "异步" || id == "返回" ||
           id == "如果" || id == "否则" || id == "当" || id == "对于" || id == "在" || id == "真" || id == "假" ||
           id == "等待" || id == "循环" || id == "中断" || id == "继续" || id == "匹配" || id == "跳转" ||
           id == "抛出" || id == "捕获" || id == "尝试" || id == "选项" ||
           id == "拥有" || id == "借用" || id == "移动" || id == "克隆" || id == "释放" || id == "新建" ||
           id == "并行" || id == "并发" || id == "任务" || id == "启动" || id == "线程" || id == "锁" || id == "原子" ||
           id == "通道" || id == "选择" || id == "情况" || id == "未来" ||
           id == "长度" || id == "输入" || id == "包" || id == "导入" ||
           id == "导出" || id == "作为" || id == "公开" || id == "私有" || id == "模块" ||
           id == "方法" || id == "枚举" ||
           id == "联合体" || id == "实现" || id == "特性" || id == "主程序入口" ||
           id == "等于" || id == "不等于" || id == "大于" || id == "小于" || id == "大于等于" || id == "小于等于" ||
           id == "取余" || id == "加" || id == "减" || id == "乘" || id == "除" {
            panic!("Keyword used as receiver identifier: {}", id);
        }
        id.to_string()
    },
};


IdentifierExpression: AstNode = {
    <name:Identifier> => AstNode::标识符表达式(IdentifierExpression {
        name,
        span: Default::default(),
    }),
};

ChannelTypeConstructor: TypeNode = {
    "通道" "<" <element_type:Type> ">" => TypeNode::通道类型(ChannelType {
        element_type: Box::new(element_type),
    }),
};
