// 循环语句示例
包 主程序;

函数 测试当语句() {
    打印("=== 当语句 ===");
    变量 i = 0;
    当 i < 5 {
        打印(i);
        i = i + 1;
    }
}

函数 测试计数循环() {
    打印("=== 计数循环 ===");
    变量 总和 = 0;
    变量 n = 1;
    当 n <= 10 {
        总和 = 总和 + n;
        n = n + 1;
    }
    打印("1到10的和:");
    打印(总和);
}

函数 入口() {
    测试当语句();
    测试计数循环();
    打印("测试完成");
}
