// 变量和类型示例
包 主程序;

函数 入口() {
    // 基本变量声明
    变量 x: 整数 = 10;
    变量 名字 = "张三";  // 类型推断

    // 常量声明（不可更改）
    常量 圆周率: 浮点数 = 3.14159;

    // 变量可以重新赋值
    变量 计数器 = 0;
    计数器 = 计数器 + 1;

    打印("整数值:");
    打印(x);
    打印("名字:");
    打印(名字);
    打印("圆周率:");
    打印(圆周率);
    打印("计数器:");
    打印(计数器);
}
