// 递归函数示例
包 主程序;

// 阶乘计算
函数 阶乘(n: 整数): 整数 {
    如果 n <= 1 {
        返回 1;
    }
    返回 n * 阶乘(n - 1);
}

// 斐波那契数列
函数 斐波那契(n: 整数): 整数 {
    如果 n <= 1 {
        返回 n;
    }
    返回 斐波那契(n - 1) + 斐波那契(n - 2);
}

函数 入口() {
    打印("=== 递归函数示例 ===");

    打印("5! =");
    打印(阶乘(5));

    打印("6! =");
    打印(阶乘(6));

    打印("斐波那契(10) =");
    打印(斐波那契(10));
}
