// 方法定义示例
包 主程序;

类型 矩形 {
    整数 宽度;
    整数 高度;
}

// 方法：计算面积
函数 (自身 矩形) 面积(): 整数 {
    返回 自身.宽度 * 自身.高度;
}

// 方法：计算周长
函数 (自身 矩形) 周长(): 整数 {
    返回 2 * (自身.宽度 + 自身.高度);
}

// 方法：显示信息
函数 (自身 矩形) 显示() {
    打印("宽度:");
    打印(自身.宽度);
    打印("高度:");
    打印(自身.高度);
}

函数 入口() {
    打印("=== 方法定义示例 ===");

    变量 rect = (矩形 { 宽度: 10, 高度: 5 });

    打印("矩形尺寸:");
    rect.显示();

    打印("面积:");
    打印(rect.面积());

    打印("周长:");
    打印(rect.周长());
}
