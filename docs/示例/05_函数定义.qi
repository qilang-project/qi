// 函数定义示例
包 主程序;

// 无参数无返回值函数
函数 问候() {
    打印("你好!");
}

// 带返回值函数
函数 加法(a: 整数, b: 整数): 整数 {
    返回 a + b;
}

// 多参数函数
函数 计算面积(宽: 整数, 高: 整数): 整数 {
    返回 宽 * 高;
}

// 递归函数
函数 阶乘(n: 整数): 整数 {
    如果 n <= 1 {
        返回 1;
    }
    返回 n * 阶乘(n - 1);
}

函数 入口() {
    问候();

    变量 和 = 加法(5, 3);
    打印("5 + 3 =");
    打印(和);

    变量 面积 = 计算面积(4, 5);
    打印("4 x 5 =");
    打印(面积);

    变量 阶乘值 = 阶乘(5);
    打印("5! =");
    打印(阶乘值);
}
