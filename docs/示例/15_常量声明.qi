// 常量声明示例
包 主程序;

函数 入口() {
    打印("=== 常量声明示例 ===");

    // 常量不能重新赋值
    常量 最大值: 整数 = 100;
    常量 圆周率: 浮点数 = 3.14159;
    常量 应用名称: 字符串 = "Qi演示程序";

    打印("最大值:");
    打印(最大值);

    打印("圆周率:");
    打印(圆周率);

    打印("应用名称:");
    打印(应用名称);

    // 变量可以重新赋值
    变量 计数 = 0;
    计数 = 计数 + 1;
    打印("计数:");
    打印(计数);
}
