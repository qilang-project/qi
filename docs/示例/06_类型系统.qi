// 类型系统示例
包 主程序;

类型 点 {
    整数 横坐标;
    整数 纵坐标;
}

类型 人物 {
    字符串 姓名;
    整数 年龄;
}

函数 入口() {
    // 创建自定义类型实例
    变量 原点 = (点 { 横坐标: 0, 纵坐标: 0 });

    打印("原点坐标:");
    打印(原点.横坐标);
    打印(原点.纵坐标);

    // 创建点
    变量 点1 = (点 { 横坐标: 10, 纵坐标: 20 });
    打印("点1坐标:");
    打印(点1.横坐标);
    打印(点1.纵坐标);

    // 创建人物
    变量 张三 = (人物 { 姓名: "张三", 年龄: 25 });

    打印("姓名:");
    打印(张三.姓名);
    打印("年龄:");
    打印(张三.年龄);
}
