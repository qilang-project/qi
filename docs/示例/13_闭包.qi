// 闭包示例（概念演示）
// 注意：当前编译器闭包功能正在开发中
包 主程序;

// 使用普通函数演示闭包概念
函数 加一(x: 整数): 整数 {
    返回 x + 1;
}

函数 相加(a: 整数, b: 整数): 整数 {
    返回 a + b;
}

函数 入口() {
    打印("=== 闭包概念 ===");
    打印("闭包语法: 闭包 (参数): 返回类型 { 表达式 }");

    // 使用函数演示
    变量 值 = 加一(5);
    打印("5 + 1 =");
    打印(值);

    变量 总和 = 相加(3, 4);
    打印("3 + 4 =");
    打印(总和);
}
