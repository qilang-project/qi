// 浮点数运算示例
包 主程序;

函数 入口() {
    打印("=== 浮点数运算示例 ===");

    变量 a: 浮点数 = 3.14;
    变量 b: 浮点数 = 2.0;

    打印("a = 3.14, b = 2.0");

    打印("a + b =");
    打印(a + b);

    打印("a - b =");
    打印(a - b);

    打印("a * b =");
    打印(a * b);

    打印("a / b =");
    打印(a / b);

    // 混合运算
    变量 半径: 浮点数 = 5.0;
    变量 圆周率: 浮点数 = 3.14159;
    变量 圆的面积 = 圆周率 * 半径 * 半径;
    打印("半径为5的圆面积:");
    打印(圆的面积);
}
