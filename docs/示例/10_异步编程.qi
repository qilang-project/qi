// 异步编程示例
包 主程序;

函数 异步计算(值: 整数): 未来<整数> {
    返回 值 * 2;
}

函数 获取消息(): 未来<字符串> {
    返回 "异步消息";
}

函数 入口() {
    打印("=== 异步编程示例 ===");

    // 调用返回未来类型的函数
    变量 未来值: 未来<整数> = 异步计算(21);

    // 等待结果
    变量 计算结果: 整数 = 等待 未来值;
    打印("异步计算结果:");
    打印(计算结果);

    // 直接等待函数调用
    变量 直接结果: 整数 = 等待 异步计算(30);
    打印("直接等待结果:");
    打印(直接结果);

    // 字符串未来类型
    变量 消息: 字符串 = 等待 获取消息();
    打印("获取的消息:");
    打印(消息);
}
